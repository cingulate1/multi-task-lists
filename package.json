{
  "name": "multi-task-lists",
  "productName": "Multi-Task Lists",
  "description": "Dual-face dependency-gated to-do board",
  "author": { "name": "Phase Space" },
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist": "electron-builder --win portable"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "local.multi-task-lists",
    "productName": "Multi-Task Lists",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*", "build/icon.ico"],
    "win": { "target": ["portable"], "icon": "build/icon.ico" },
    "portable": { "artifactName": "MultiTaskLists.exe" },
    "publish": null
  }
}
